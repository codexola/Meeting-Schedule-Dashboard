# Frontend environment variables
# Copy to .env:  cp .env.example .env

# URL of the local backend API (Express + PostgreSQL)
BACKEND_URL=http://103.179.45.111:4000

# =============================================================================
# VERCEL PRODUCTION
# Set in Vercel Dashboard → Settings → Environment Variables:
#   BACKEND_URL = http://103.179.45.111:4000
#
# Requirements for Vercel + local backend:
# 1. Backend running on your server (npm run dev --prefix backend)
# 2. PostgreSQL running locally (npx prisma dev)
# 3. Port 4000 open on 103.179.45.111 for Vercel to proxy API calls
# =============================================================================
