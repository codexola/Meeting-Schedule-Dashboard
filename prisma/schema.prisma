generator client {
  provider = "prisma-client"
  output   = "../backend/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id              String   @id @default(cuid())
  name            String   @unique
  caller          String?
  jobSiteName     String?
  jobPositionLink String?
  contactName     String?
  contactPosition String?
  chatLink        String?
  jobCondition    String   @default("OK")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stages   CompanyStage[]
  meetings Meeting[]
}

model CompanyStage {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stage           String
  outcome         String    @default("NOT_STARTED")
  meetingLink     String?
  scheduledDate   DateTime? @db.Date
  scheduledHour   Int?
  scheduledMinute Int?
  updatedAt       DateTime  @updatedAt

  @@unique([companyId, stage])
}

model Meeting {
  id              String   @id @default(cuid())
  meetingDate     DateTime @db.Date
  meetingHour     Int
  meetingMinute   Int      @default(0)
  meetingLink     String?
  companyName     String
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  caller          String?
  jobSiteName     String?
  jobPositionLink String?
  interviewer     String?
  contactName     String?
  contactPosition String?
  chatLink        String?
  jobStatus       String   @default("JOB_APPLICATION_RECEIVED")
  jobCondition    String   @default("OK")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([meetingDate, meetingHour, meetingMinute])
  @@index([jobCondition])
  @@index([companyId])
  @@index([companyName])
}
